rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ⚠️ 현재 Firebase Auth 미사용으로 request.auth가 항상 null
    // 실서비스 전환 시 Firebase Authentication 도입 후 아래 주석 규칙 적용 필요

    // 사용자 컬렉션
    match /users/{userId} {
      allow read: if true;
      // 쓰기: 필수 필드 검증
      allow create: if request.resource.data.keys().hasAll(['uid', 'name', 'department'])
                    && request.resource.data.name is string
                    && request.resource.data.department is string;
      allow update: if true;
      allow delete: if false; // 사용자 삭제 금지
    }

    // 운행 컬렉션
    match /routes/{routeId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['driverId', 'driverName', 'sourceName', 'destName', 'status'])
                    && request.resource.data.status == 'active';
      allow update: if true;
      allow delete: if false; // route 삭제 금지 (상태 변경만)
    }

    // 매칭 컬렉션
    match /rides/{rideId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['routeId', 'driverId', 'passengerId', 'status'])
                    && request.resource.data.status == 'pending';
      allow update: if true;
      allow delete: if false; // ride 삭제 금지 (상태 변경만)
    }

    // 채팅 컬렉션
    match /chats/{rideId}/messages/{messageId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['senderId', 'senderName', 'text', 'createdAt']);
      allow update, delete: if false; // 메시지 수정/삭제 금지
    }

    // 기타 컬렉션 — 기본 차단
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}

