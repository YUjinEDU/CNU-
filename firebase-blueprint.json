{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the carpool app",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "User's full name" },
        "department": { "type": "string", "description": "User's department" },
        "role": { "type": "string", "enum": ["driver", "passenger", "both"], "description": "User's role" },
        "savedAddresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          }
        },
        "isVerified": { "type": "boolean", "description": "Whether the user is verified as CNU staff" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["uid", "name", "department", "role", "createdAt"]
    },
    "Route": {
      "title": "Route",
      "description": "A route offered by a driver",
      "type": "object",
      "properties": {
        "driverId": { "type": "string", "description": "UID of the driver" },
        "driverName": { "type": "string" },
        "vehicleInfo": { "type": "string" },
        "plateNumber": { "type": "string" },
        "departureTime": { "type": "string" },
        "sourceName": { "type": "string" },
        "destName": { "type": "string" },
        "path": { "type": "string", "description": "JSON stringified array of lat/lng coordinates" },
        "status": { "type": "string", "enum": ["active", "matched", "completed", "cancelled"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["driverId", "driverName", "sourceName", "destName", "path", "status", "createdAt"]
    },
    "Ride": {
      "title": "Ride",
      "description": "A ride request/match for a passenger",
      "type": "object",
      "properties": {
        "routeId": { "type": "string" },
        "passengerId": { "type": "string" },
        "passengerName": { "type": "string" },
        "pickupLat": { "type": "number" },
        "pickupLng": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "en_route", "in_transit", "completed", "cancelled"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["routeId", "passengerId", "passengerName", "pickupLat", "pickupLng", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/routes/{routeId}": {
      "schema": { "$ref": "#/entities/Route" },
      "description": "Active and past routes"
    },
    "/rides/{rideId}": {
      "schema": { "$ref": "#/entities/Ride" },
      "description": "Ride requests and matches"
    }
  }
}
